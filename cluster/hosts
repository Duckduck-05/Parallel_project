# OpenMPI hostfile - 4 nodes.
# slots = max processes per machine. Capped to 12 on every node (the smallest node has 12
# cores) so the cluster is HOMOGENEOUS: each rank gets its own physical core everywhere and
# all ranks do equal work -> balanced makespan, comparable timing (clean speedup/granularity).
# Total = 4 x 12 = 48 ranks. node1..node4 resolve via /etc/hosts (see hosts.sample).
# Run: mpirun --hostfile cluster/hosts -np 48 ./cpp/tsp_island data/cities_1000.txt --sync 50
node1 slots=12
node2 slots=12
node3 slots=12
node4 slots=12
