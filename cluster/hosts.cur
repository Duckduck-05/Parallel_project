# Full cluster: all 4 members (node1 + node2 + node4 + node3).
# Run:  bash cluster/run_cluster.sh cluster/hosts.cur 4 hostname
# Rank order no longer affects the algorithm: result sharing is a global-best broadcast
# (Allreduce + Bcast over all ranks), not neighbour-to-neighbour, so adjacency is irrelevant.
node1 slots=2
node2 slots=2
node4 slots=2
node3 slots=2
